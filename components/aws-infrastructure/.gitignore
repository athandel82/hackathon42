# Terraform — local state, plugins, caches
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Plan output / artifacts
*.tfplan
*.tfplan.*

# Variable files that may carry secrets or environment-specific overrides.
# The committed envs/dev/dev.tfvars is intentionally tracked; ignore the rest.
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive
*.pem
*.key

# OS / editor noise
.DS_Store
*.swp
