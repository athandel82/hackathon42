<mxfile host="app.diagrams.net" agent="kiro" version="24.0.0">
  <diagram id="sdv-deploy" name="SDV — Deployment Architecture">
    <mxGraphModel dx="2000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1850" pageHeight="1820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== TITLE ===================== -->
        <mxCell id="title" value="SDV — &quot;Still Defined Vehicle&quot; · AWS Deployment Architecture (Terraform, us-east-1, single dev env)" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Read-only ECU change impact analysis. Two in-process Strands agents on Lambda + Amazon Bedrock (Claude). Note: this design uses the Strands Agents SDK inside Lambda — NOT Bedrock AgentCore Runtime (see callout)." style="text;html=1;fontSize=12;fontStyle=2;align=left;verticalAlign=middle;fontColor=#5A6C86;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="1400" height="22" as="geometry" />
        </mxCell>

        <!-- ===================== ZONES ===================== -->
        <mxCell id="zClient" value="CLIENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#5A6C86;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=left;spacingLeft=10;spacingTop=6;fontColor=#5A6C86;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="zVPC" value="VPC — reused public subnet + security group (Frontend hosting only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#8C4FFF;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=10;spacingTop=6;fontColor=#8C4FFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="340" height="250" as="geometry" />
